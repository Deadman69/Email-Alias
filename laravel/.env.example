APP_NAME=EmailAlias
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Domain used for generated email addresses (must match MX record)
APP_DOMAIN=example.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# ── EmailAlias ───────────────────────────────────────────────────────────────
SMTP_INTERNAL_SECRET=changeme_smtp_secret
ALIAS_MAX_PER_USER=20
ALIAS_ALLOW_PERMANENT=true
ADMIN_CAN_READ_EMAILS=false
CLEANUP_EMAIL_RETENTION_DAYS=30

# ── SSO — common ──────────────────────────────────────────────────────────────
# Set SSO_ENABLED=true to enable single sign-on.
# SSO_PROVIDER: azure | keycloak | saml
SSO_ENABLED=false
SSO_PROVIDER=azure
LOCAL_AUTH_ENABLED=true
REGISTRATION_ENABLED=false

# ── SSO — Azure AD (Socialite) ────────────────────────────────────────────────
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=common
# Redirect URI to register in Azure App Registration:
# {APP_URL}/auth/sso/callback

# ── SSO — Keycloak / Generic OIDC ─────────────────────────────────────────────
# Covers Keycloak, Okta, Auth0, Dex, and any OIDC-compliant IdP.
# Discovery document is auto-fetched from {OIDC_ISSUER_URL}/.well-known/openid-configuration
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_ISSUER_URL=
# e.g. https://keycloak.example.com/realms/myrealm
# Redirect URI to register in your OIDC client:
# {APP_URL}/auth/sso/callback

# ── SSO — SAML 2.0 ────────────────────────────────────────────────────────────
# Requires: composer require aacotroneo/laravel-saml2
# SP metadata endpoint: {APP_URL}/auth/saml/metadata
SAML_IDP_ENTITY_ID=
SAML_IDP_SSO_URL=
SAML_IDP_SLO_URL=
SAML_IDP_CERTIFICATE=
# PEM-encoded — no -----BEGIN/END CERTIFICATE----- header/footer
SAML_SP_ENTITY_ID=
# Defaults to APP_URL if left blank

# ── SCIM 2.0 provisioning ─────────────────────────────────────────────────────
# Generate a strong random string (min 32 chars). Stored encrypted in DB.
# Configure in Azure Enterprise App → Provisioning → Tenant URL: {APP_URL}/scim/v2
SCIM_BEARER_TOKEN=

# ── Broadcasting (Reverb) ──────────────────────────────────────────────────
BROADCAST_CONNECTION=reverb

REVERB_APP_ID=emailalias
REVERB_APP_KEY=changeme_reverb_key
REVERB_APP_SECRET=changeme_reverb_secret
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
