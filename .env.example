# ─── Application ──────────────────────────────────────────────────────────────
APP_NAME="EmailAlias"
APP_KEY=base64:xxxxxxxxxxxxxxxx
APP_ENV=production
APP_DEBUG=false
APP_URL=https://emailalias.your_domain.com

# ─── Session ──────────────────────────────────────────────────────────────────
SESSION_DRIVER=database

# ─── Database ──────────────────────────────────────────────────────────
DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=emailalias
DB_USERNAME=emailalias
DB_PASSWORD=changeme_db_password          # ⚠ Change it 

# ─── SMTP Receiver ────────────────────────────────────────────────────────────
SMTP_RECEIVER_PORT=25
SMTP_INTERNAL_SECRET=changeme_smtp_secret # ⚠ Secret shared smtp-server <=> Laravel

# ─── WebSocket (Reverb) ───────────────────────────────────────────────────────
REVERB_APP_ID=emailalias
REVERB_APP_KEY=changeme_reverb_key        # ⚠ Change it 
REVERB_APP_SECRET=changeme_reverb_secret  # ⚠ Change it 
REVERB_HOST=0.0.0.0
REVERB_PORT=8080
REVERB_SCHEME=https
# Tune based on available RAM (~2 MB/connection). Scale horizontally with sticky-session LB for >1000 users.
REVERB_MAX_CONNECTIONS=1000

# ─── Object Storage (MinIO / S3) ──────────────────────────────────────────────
# If you use MinIO multi-nodes use 's3' disk :
# ATTACHMENT_DISK=s3
ATTACHMENT_DISK=local
MINIO_ROOT_USER=emailalias
MINIO_ROOT_PASSWORD=changeme_minio_password  # ⚠ Change it 

# Variables S3 (used only if ATTACHMENT_DISK=s3) :
AWS_ACCESS_KEY_ID=emailalias
AWS_SECRET_ACCESS_KEY=changeme_minio_password
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=emailalias-attachments
AWS_ENDPOINT=http://minio:9000
AWS_USE_PATH_STYLE_ENDPOINT=true
# ─────────────────────────────────────────────────────────────────────────────
