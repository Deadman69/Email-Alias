# ─── Application ──────────────────────────────────────────────────────────────
APP_NAME="EmailAlias"
APP_ENV=production
APP_DEBUG=false
APP_KEY=                                  # php artisan key:generate
APP_URL=https://emailalias.votre-domaine.com
APP_DOMAIN=votre-domaine.com             # Domaine MX des adresses générées

# ─── Session ──────────────────────────────────────────────────────────────────
# Utiliser 'database' pour activer la gestion des sessions actives dans les settings.
SESSION_DRIVER=database

# ─── Base de données ──────────────────────────────────────────────────────────
DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=emailalias
DB_USERNAME=emailalias
DB_PASSWORD=changeme_db_password          # ⚠ Changer obligatoirement

# ─── SMTP Receiver ────────────────────────────────────────────────────────────
SMTP_RECEIVER_PORT=25
SMTP_INTERNAL_SECRET=changeme_smtp_secret # ⚠ Secret partagé smtp-server ↔ Laravel
SMTP_ALLOWED_DOMAIN=mail.votre-domaine.com # Domaine(s) acceptés (virgule si plusieurs). Laisser vide = open relay ⚠

# ─── WebSocket (Reverb) ───────────────────────────────────────────────────────
REVERB_APP_ID=emailalias
REVERB_APP_KEY=changeme_reverb_key        # ⚠ Changer obligatoirement
REVERB_APP_SECRET=changeme_reverb_secret  # ⚠ Changer obligatoirement
REVERB_HOST=0.0.0.0
REVERB_PORT=8080
REVERB_SCHEME=https
# Tune based on available RAM (~2 MB/connection). Scale horizontally with sticky-session LB for >1000 users.
REVERB_MAX_CONNECTIONS=1000

# ─── Object Storage (MinIO / S3) ──────────────────────────────────────────────
# Par défaut : stockage local (volumes Docker). Pour MinIO multi-nœud :
# ATTACHMENT_DISK=s3
ATTACHMENT_DISK=local
MINIO_ROOT_USER=emailalias
MINIO_ROOT_PASSWORD=changeme_minio_password  # ⚠ Changer obligatoirement

# Variables S3 (utilisées si ATTACHMENT_DISK=s3) :
AWS_ACCESS_KEY_ID=emailalias
AWS_SECRET_ACCESS_KEY=changeme_minio_password
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=emailalias-attachments
AWS_ENDPOINT=http://minio:9000
AWS_USE_PATH_STYLE_ENDPOINT=true
# ─────────────────────────────────────────────────────────────────────────────

# ─── Prometheus metrics ────────────────────────────────────────────────────────
# Laisser vide pour désactiver l'endpoint /metrics (recommandé si non utilisé).
# Utiliser un token fort (ex : openssl rand -base64 32).
METRICS_BEARER_TOKEN=
# ─────────────────────────────────────────────────────────────────────────────

# ─────────────────────────────────────────────────────────────────────────────
# Tout le reste (SSO, 2FA, limites, rétention, auth locale…) se configure
# directement dans l'application via /admin/settings (Super Admin).
# Les secrets sensibles (ex : client_secret Azure) sont chiffrés en base.
# ─────────────────────────────────────────────────────────────────────────────
