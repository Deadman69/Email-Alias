# ─── Application ──────────────────────────────────────────────────────────────
APP_NAME="EmailAlias"
APP_ENV=production
APP_DEBUG=false
APP_URL=https://emailalias.votre-domaine.com
APP_DOMAIN=votre-domaine.com

# ─── Base de données ──────────────────────────────────────────────────────────
DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=emailalias
DB_USERNAME=emailalias
DB_PASSWORD=changeme_db_password

# ─── SSO Azure AD ─────────────────────────────────────────────────────────────
SSO_ENABLED=false
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=
AZURE_REDIRECT_URI="${APP_URL}/auth/sso/callback"

# ─── Authentification locale ──────────────────────────────────────────────────
LOCAL_AUTH_ENABLED=true
REGISTRATION_ENABLED=false

# ─── 2FA ──────────────────────────────────────────────────────────────────────
TWO_FACTOR_ENABLED=true
TWO_FACTOR_REQUIRED=false

# ─── Adresses email ───────────────────────────────────────────────────────────
ALIAS_MAX_PER_USER=20
ALIAS_DEFAULT_TYPE=session
ALIAS_ALLOW_PERMANENT=true
ALIAS_MAX_EMAIL_SIZE_BYTES=10485760      # 10 MB — emails plus lourds : headers only
ALIAS_MAX_ATTACHMENT_SIZE_BYTES=5242880  # 5 MB par pièce jointe

# ─── Admin ────────────────────────────────────────────────────────────────────
ADMIN_CAN_READ_EMAILS=false

# ─── SMTP Receiver ────────────────────────────────────────────────────────────
SMTP_RECEIVER_PORT=25
SMTP_INTERNAL_SECRET=changeme_smtp_secret

# ─── WebSocket (Reverb) ───────────────────────────────────────────────────────
REVERB_APP_ID=emailalias
REVERB_APP_KEY=changeme_reverb_key
REVERB_APP_SECRET=changeme_reverb_secret
REVERB_HOST=0.0.0.0
REVERB_PORT=8080
REVERB_SCHEME=https

# ─── Nettoyage automatique ────────────────────────────────────────────────────
CLEANUP_EXPIRED_ALIASES=true
CLEANUP_EMAIL_RETENTION_DAYS=30
